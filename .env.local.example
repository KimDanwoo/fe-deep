# ── Supabase (공개) ──────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Supabase (서버 전용) ─────────────────────────────────────
# ⚠️ service_role 키는 RLS를 우회하는 최고 권한 키입니다.
#    절대 NEXT_PUBLIC_ 접두사를 붙이지 마세요 (브라우저 번들 노출 = DB 전체 노출).
SUPABASE_SERVICE_ROLE_KEY=

# ── 어드민 ──────────────────────────────────────────────────
NEXT_PUBLIC_ADMIN_EMAILS=   # 클라이언트 UI 노출 판단용 (콤마 구분)
ADMIN_EMAILS=               # 서버 측 권한 검증용 (콤마 구분)

# ── 질문 자동 생성 스크립트 (Gemini) ─────────────────────────
GEMINI_API_KEY=

# ── 배포 도메인 (메타데이터·사이트맵) ────────────────────────
NEXT_PUBLIC_SITE_URL=https://fedeep.kr
